generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Profile {
  id        String   @id @default(cuid())
  url       String   @unique
  name      String?
  title     String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastSyncedAt DateTime?
  posts        Post[]
}

model Post {
  id         String      @id @default(cuid())
  content    String
  postUrl    String      @unique
  authorId   String
  author     Profile     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postedAt   DateTime?
  likes      Int         @default(0)
  comments   Int         @default(0)
  scrapedAt  DateTime    @default(now())
  commenters Commenter[]
}

model Commenter {
  id          String    @id @default(cuid())
  postId      String
  post        Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  name        String?
  linkedinUrl String
  title       String?
  avatarUrl   String?
  scrapedAt   DateTime  @default(now())
  icpScore    Int?
  intentLevel String?
  reasoning   String?
  suggestedDm String?
  evaluatedAt DateTime?

  @@unique([postId, linkedinUrl])
}

model Interest {
  id          String   @id @default(cuid())
  keyword     String   @unique
  description String?
  createdAt   DateTime @default(now())
}

model CompanyContext {
  id                String   @id @default("default")
  companyName       String   @default("")
  valueProp         String   @default("")
  targetRoles       String   @default("[]")
  targetCompanySize String   @default("")
  antiIcpSignals    String   @default("[]")
  customPrompt      String   @default("")
  updatedAt         DateTime @updatedAt
}

model SyncJob {
  id          String    @id @default(cuid())
  status      String    @default("pending")
  total       Int       @default(0)
  processed   Int       @default(0)
  succeeded   Int       @default(0)
  failed      Int       @default(0)
  posts       Int       @default(0)
  commenters  Int       @default(0)
  log         String    @default("[]")
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
}
