generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Profile {
  id        String   @id @default(cuid())
  url       String   @unique
  name      String?
  title     String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastSyncedAt DateTime?
  posts        Post[]
}

model Post {
  id         String      @id @default(cuid())
  content    String
  postUrl    String      @unique
  authorId   String
  author     Profile     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postedAt   DateTime?
  likes      Int         @default(0)
  comments   Int         @default(0)
  scrapedAt  DateTime    @default(now())
  commenters Commenter[]
}

model Commenter {
  id          String    @id @default(cuid())
  postId      String
  post        Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  name        String?
  linkedinUrl String
  title       String?
  avatarUrl   String?
  scrapedAt   DateTime  @default(now())
  icpScore    Int?
  intentLevel String?
  reasoning   String?
  suggestedDm String?
  evaluatedAt DateTime?

  @@unique([postId, linkedinUrl])
}

model Interest {
  id          String   @id @default(cuid())
  keyword     String   @unique
  description String?
  createdAt   DateTime @default(now())
}

model CompanyContext {
  id                String   @id @default("default")
  companyName       String   @default("")
  valueProp         String   @default("")
  targetRoles       String   @default("[]")
  targetCompanySize String   @default("")
  antiIcpSignals    String   @default("[]")
  customPrompt      String   @default("")
  updatedAt         DateTime @updatedAt
}

model SyncJob {
  id          String    @id @default(cuid())
  status      String    @default("pending")
  total       Int       @default(0)
  processed   Int       @default(0)
  succeeded   Int       @default(0)
  failed      Int       @default(0)
  posts       Int       @default(0)
  commenters  Int       @default(0)
  log         String    @default("[]")
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
}


model ContentIdea {
  id             String    @id @default(cuid())
  srNo           Int?      
  title          String    
  sourceUrl      String?   
  whyTalkAboutIt String?   
  angle          String?   
  context        String?   
  inputRequired  String?   
  topics         String    @default("[]")
  status         String    @default("Idea")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ── Content Intelligence Models ─────────────────────────────

model ContentSource {
  id            String        @id @default(cuid())
  name          String
  platform      String
  url           String        @unique
  rssFeedUrl    String?
  lastScrapedAt DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  posts         ContentPost[]
}

model ContentPost {
  id          String              @id @default(cuid())
  sourceId    String
  source      ContentSource       @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  platform    String
  authorName  String?
  authorUrl   String?
  content     String
  postUrl     String              @unique
  postedAt    DateTime?
  scrapedAt   DateTime            @default(now())
  topics      String              @default("[]")
  suggestions ContentSuggestion[]
}

model Persona {
  id                 String              @id @default(cuid())
  name               String
  role               String
  linkedinProfileUrl String?
  contextMarkdown    String              @default("")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  suggestions        ContentSuggestion[]
}

model ContentSuggestion {
  id            String      @id @default(cuid())
  personaId     String
  persona       Persona     @relation(fields: [personaId], references: [id], onDelete: Cascade)
  contentPostId String
  contentPost   ContentPost @relation(fields: [contentPostId], references: [id], onDelete: Cascade)
  suggestion    String
  angle         String?
  hookIdea      String?
  status        String      @default("pending")
  dismissReason  String?
  createdAt     DateTime    @default(now())
}
